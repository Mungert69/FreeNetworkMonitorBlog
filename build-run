#!/bin/sh
set -eu

npm install 

SOURCE_APIPICGEN="${HOME}/code/securefiles/live/apipicgen"
DEST_APIPICGEN="./public/blogpics/apipicgen"

if [ ! -d "${SOURCE_APIPICGEN}" ]; then
  echo "Missing source image directory: ${SOURCE_APIPICGEN}"
  exit 1
fi

mkdir -p ./public/img
mkdir -p ./public/blogpics
mkdir -p "${DEST_APIPICGEN}"
if command -v rsync >/dev/null 2>&1; then
  rsync -a --exclude='*-orig.*' "${SOURCE_APIPICGEN}/" "${DEST_APIPICGEN}/"
else
  find "${SOURCE_APIPICGEN}" -maxdepth 1 -type f ! -name '*-orig.*' -exec cp -a {} "${DEST_APIPICGEN}/" \;
fi

cp ./public/runConfig-live.js ./public/runConfig.js
cp ./public/runConfig-live.json ./public/runConfig.json
npm run export
mkdir -p ./out/images
mkdir -p ./out/blogpics
docker buildx inspect multiarch-builder >/dev/null 2>&1 || docker buildx create --name multiarch-builder --use
docker buildx use multiarch-builder
docker buildx inspect --bootstrap
docker buildx build \
  --platform linux/amd64,linux/arm64 \
  --file ./Dockerfile \
  --tag mungert/networkmonitorblog:1.3.0 \
  --push \
  .
