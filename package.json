{
  "name": "Ready For Quantum Blogs",
  "description": "Ready For Quantum Blogs",
  "version": "1.3.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' node lib/jsonGenerator.js && next dev",
    "build": "node lib/jsonGenerator.js && node lib/generate-sitemap.js && next build",
    "export": "rm -rf ./out && node lib/jsonGenerator.js && node lib/generate-sitemap.js && next build && node lib/validate-export.js",
    "validate-export": "node lib/validate-export.js",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "node --test tests/**/*.test.cjs",
    "test:ui": "vitest run",
    "lint": "echo \"ESLint removed for this project\"",
    "start": "next start",
    "generate-sitemap": "node lib/generate-sitemap.js"
  },
  "overrides": {
    "prismjs": "^1.30.0"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "axios-retry": "^4.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "disqus-react": "^1.1.5",
    "frontmatter": "^0.0.3",
    "fs": "^0.0.1-security",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "he": "^1.2.0",
    "import": "^0.0.6",
    "isomorphic-unfetch": "^4.0.2",
    "marked": "^17.0.4",
    "next": "^16.1.6",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^2.1.0",
    "react-icons": "^5.0.1",
    "react-lite-youtube-embed": "^3.5.1",
    "react-mailchimp-subscribe": "^2.1.3",
    "react-promise-tracker": "^2.1.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.19",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.38",
    "sass": "^1.72.0",
    "sharp": "^0.34.5",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "vitest": "^4.0.18"
  }
